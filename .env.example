# Copy to .env and fill in real values. .env is gitignored.

# Postgres — using Neon serverless Postgres in this project.
# Get a connection string at https://neon.tech and paste it here.
# Format:
#   postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Redis (used for caching). With docker-compose, this points at the redis service.
REDIS_URL=redis://redis:6379

# Backend
PORT=3000
NODE_ENV=development

# Frontend (Vite — read at build time)
VITE_API_BASE=http://localhost:3000
